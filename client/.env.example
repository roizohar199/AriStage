# Environment Variables - Client

# Nagish.li Accessibility Toolbar Configuration
# Enable/disable the Nagish.li plugin
VITE_NAGISHLI_ENABLED=true

# Language for Nagish.li interface
# Options: 'he' (Hebrew), 'en' (English), 'ar' (Arabic)
VITE_NAGISHLI_LANG=he

# Position of the Nagish.li toolbar button
# Options: 'br' (bottom-right), 'bl' (bottom-left), 'tr' (top-right), 'tl' (top-left)
VITE_NAGISHLI_POS=br

# API Origin (existing)
VITE_API_ORIGIN=http://localhost:5000
